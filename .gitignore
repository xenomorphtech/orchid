# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
orchid_temp-*.tar

.claude_tokens.json
.env
.orchid/*
!.orchid/facts.local.example.json

# CubDB persistent data
/priv/data/
/priv/codex_sdk/node_modules/

# at-scale discriminator grind scratch (paid-model-gated; not part of the repo)
/grind*.log
/grind*.sh
/priv/autonomy/discriminators_gvr.json
/priv/autonomy/*_FAILED_*.json
/priv/autonomy/*_CONTAMINATED.json
/priv/autonomy/discriminators_*.json
/priv/autonomy/*_NOAPPROVAL*.json
/priv/autonomy/easy_gvr.json
